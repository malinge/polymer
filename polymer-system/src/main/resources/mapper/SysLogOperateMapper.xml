<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.polymer.system.mapper.SysLogOperateMapper">

    <resultMap type="SysLogOperateEntity" id="SysLogOperateResult">
        <result property="id" column="id"/>
        <result property="module" column="module"/>
        <result property="name" column="name"/>
        <result property="reqUri" column="req_uri"/>
        <result property="reqMethod" column="req_method"/>
        <result property="reqParams" column="req_params"/>
        <result property="ip" column="ip"/>
        <result property="address" column="address"/>
        <result property="userAgent" column="user_agent"/>
        <result property="operateType" column="operate_type"/>
        <result property="duration" column="duration"/>
        <result property="status" column="status"/>
        <result property="userId" column="user_id"/>
        <result property="realName" column="real_name"/>
        <result property="resultMsg" column="result_msg"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectSysLogOperateVo">
        select id,
               module,
               name,
               req_uri,
               req_method,
               req_params,
               ip,
               address,
               user_agent,
               operate_type,
               duration,
               status,
               user_id,
               real_name,
               result_msg,
               create_time
        from sys_log_operate
    </sql>

    <!--查询操作日志列表-->
    <select id="selectSysLogOperateList" parameterType="com.polymer.system.query.SysLogOperateQuery"
            resultMap="SysLogOperateResult">
        <include refid="selectSysLogOperateVo"/>
        <where>
            <if test="realName != null and realName != ''">
                AND real_name like concat('%', #{realName}, '%')
            </if>
            <if test="module != null and module != ''">
                AND module like concat('%', #{module}, '%')
            </if>
            <if test="reqUri != null and reqUri != ''">
                AND req_uri like concat('%', #{reqUri}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        order by id desc
    </select>

    <!--查询操作日志-->
    <select id="selectSysLogOperateById" parameterType="Long" resultMap="SysLogOperateResult">
        <include refid="selectSysLogOperateVo"/>
        where id = #{id}
    </select>

    <!--新增操作日志-->
    <insert id="insertSysLogOperate" parameterType="SysLogOperateEntity" useGeneratedKeys="true" keyProperty="id">
        insert into sys_log_operate
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="module != null and module != ''">module,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="reqUri != null and reqUri != ''">req_uri,</if>
            <if test="reqMethod != null and reqMethod != ''">req_method,</if>
            <if test="reqParams != null and reqParams != ''">req_params,</if>
            <if test="ip != null and ip != ''">ip,</if>
            <if test="address != null and address != ''">address,</if>
            <if test="userAgent != null and userAgent != ''">user_agent,</if>
            <if test="operateType != null">operate_type,</if>
            <if test="duration != null">duration,</if>
            <if test="status != null">status,</if>
            <if test="userId != null">user_id,</if>
            <if test="realName != null and realName != ''">real_name,</if>
            <if test="resultMsg != null and resultMsg != ''">result_msg,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="module != null and module != ''">#{module},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="reqUri != null and reqUri != ''">#{reqUri},</if>
            <if test="reqMethod != null and reqMethod != ''">#{reqMethod},</if>
            <if test="reqParams != null and reqParams != ''">#{reqParams},</if>
            <if test="ip != null and ip != ''">#{ip},</if>
            <if test="address != null and address != ''">#{address},</if>
            <if test="userAgent != null and userAgent != ''">#{userAgent},</if>
            <if test="operateType != null">#{operateType},</if>
            <if test="duration != null">#{duration},</if>
            <if test="status != null">#{status},</if>
            <if test="userId != null">#{userId},</if>
            <if test="realName != null and realName != ''">#{realName},</if>
            <if test="resultMsg != null and resultMsg != ''">#{resultMsg},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <!--修改操作日志-->
    <update id="updateSysLogOperate" parameterType="SysLogOperateEntity">
        update sys_log_operate
        <set>
            <if test="id != null">id = #{id},</if>
            <if test="module != null and module != ''">module = #{module},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="reqUri != null and reqUri != ''">req_uri = #{reqUri},</if>
            <if test="reqMethod != null and reqMethod != ''">req_method = #{reqMethod},</if>
            <if test="reqParams != null and reqParams != ''">req_params = #{reqParams},</if>
            <if test="ip != null and ip != ''">ip = #{ip},</if>
            <if test="address != null and address != ''">address = #{address},</if>
            <if test="userAgent != null and userAgent != ''">user_agent = #{userAgent},</if>
            <if test="operateType != null">operate_type = #{operateType},</if>
            <if test="duration != null">duration = #{duration},</if>
            <if test="status != null">status = #{status},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="realName != null and realName != ''">real_name = #{realName},</if>
            <if test="resultMsg != null and resultMsg != ''">result_msg = #{resultMsg},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </set>
        where id = #{id}
    </update>

    <!--删除操作日志-->
    <delete id="deleteSysLogOperateById" parameterType="Long">
        delete from sys_log_operate where id = #{id}
    </delete>

</mapper>
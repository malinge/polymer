<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.polymer.system.mapper.SysLogLoginMapper">

    <resultMap id="SysLogLoginResult" type="SysLogLoginEntity">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="ip" column="ip"/>
        <result property="address" column="address"/>
        <result property="userAgent" column="user_agent"/>
        <result property="status" column="status"/>
        <result property="operation" column="operation"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectSysLogLoginVo">
        select id,
               username,
               ip,
               address,
               user_agent,
               status,
               operation,
               create_time
        from sys_log_login
    </sql>

    <!--查询登录日志列表-->
    <select id="selectSysLogLoginList" parameterType="com.polymer.system.query.SysLogLoginQuery"
            resultMap="SysLogLoginResult">
        <include refid="selectSysLogLoginVo"/>
        <where>
            <if test="username != null and username != ''">
                AND username like concat('%', #{username}, '%')
            </if>
            <if test="address != null and address != ''">
                AND address like concat('%', #{address}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        order by id desc
    </select>

    <!--新增登录日志-->
    <insert id="insertLogLogin" parameterType="SysLogLoginEntity" useGeneratedKeys="true" keyProperty="id">
        insert into sys_log_login(
        <if test="username != null and username != ''">username,</if>
        <if test="ip != null and ip != ''">ip,</if>
        <if test="address != null and address != ''">address,</if>
        <if test="userAgent != null and userAgent != ''">user_agent,</if>
        <if test="status != null">status,</if>
        <if test="operation != null">operation,</if>
        create_time)
        values(
        <if test="username != null and username != ''">#{username},</if>
        <if test="ip != null and ip != ''">#{ip},</if>
        <if test="address != null and address != ''">#{address},</if>
        <if test="userAgent != null and userAgent != ''">#{userAgent},</if>
        <if test="status != null">#{status},</if>
        <if test="operation != null">#{operation},</if>
        sysdate())
    </insert>
</mapper>
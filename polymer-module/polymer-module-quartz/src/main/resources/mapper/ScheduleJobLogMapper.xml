<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.polymer.quartz.mapper.ScheduleJobLogMapper">

    <resultMap type="ScheduleJobLogEntity" id="ScheduleJobLogResult">
        <result property="id" column="id"/>
        <result property="jobId" column="job_id"/>
        <result property="jobName" column="job_name"/>
        <result property="jobGroup" column="job_group"/>
        <result property="beanName" column="bean_name"/>
        <result property="method" column="method"/>
        <result property="params" column="params"/>
        <result property="status" column="status"/>
        <result property="error" column="error"/>
        <result property="times" column="times"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectScheduleJobLogVo">
        select id,
               job_id,
               job_name,
               job_group,
               bean_name,
               method,
               params,
               status,
               error,
               times,
               create_time
        from schedule_job_log
    </sql>

    <!--查询定时任务日志列表-->
    <select id="selectScheduleJobLogList" parameterType="com.polymer.quartz.query.ScheduleJobLogQuery"
            resultMap="ScheduleJobLogResult">
        <include refid="selectScheduleJobLogVo"/>
        <where>
            <if test="jobName != null and jobName != ''">
                AND job_name like concat('%', #{jobName}, '%')
            </if>
            <if test="jobGroup != null and jobGroup != ''">
                AND job_group like concat('%', #{jobGroup}, '%')
            </if>
            <if test="jobId != null">
                AND job_id = #{jobId})
            </if>
        </where>
        order by id desc
    </select>

    <!--查询定时任务日志-->
    <select id="selectScheduleJobLogById" parameterType="Long" resultMap="ScheduleJobLogResult">
        <include refid="selectScheduleJobLogVo"/>
        where id = #{id}
    </select>

    <!--新增定时任务日志-->
    <insert id="insertScheduleJobLog" parameterType="ScheduleJobLogEntity" useGeneratedKeys="true" keyProperty="id">
        insert into schedule_job_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="jobId != null">job_id,</if>
            <if test="jobName != null and jobName != ''">job_name,</if>
            <if test="jobGroup != null and jobGroup != ''">job_group,</if>
            <if test="beanName != null and beanName != ''">bean_name,</if>
            <if test="method != null and method != ''">method,</if>
            <if test="params != null and params != ''">params,</if>
            <if test="status != null">status,</if>
            <if test="error != null and error != ''">error,</if>
            <if test="times != null">times,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="jobId != null">#{jobId},</if>
            <if test="jobName != null and jobName != ''">#{jobName},</if>
            <if test="jobGroup != null and jobGroup != ''">#{jobGroup},</if>
            <if test="beanName != null and beanName != ''">#{beanName},</if>
            <if test="method != null and method != ''">#{method},</if>
            <if test="params != null and params != ''">#{params},</if>
            <if test="status != null">#{status},</if>
            <if test="error != null and error != ''">#{error},</if>
            <if test="times != null">#{times},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <!--修改定时任务日志-->
    <update id="updateScheduleJobLog" parameterType="ScheduleJobLogEntity">
        update schedule_job_log
        <set>
            <if test="jobId != null">job_id = #{jobId},</if>
            <if test="jobName != null and jobName != ''">job_name = #{jobName},</if>
            <if test="jobGroup != null and jobGroup != ''">job_group = #{jobGroup},</if>
            <if test="beanName != null and beanName != ''">bean_name = #{beanName},</if>
            <if test="method != null and method != ''">method = #{method},</if>
            <if test="params != null and params != ''">params = #{params},</if>
            <if test="status != null">status = #{status},</if>
            <if test="error != null and error != ''">error = #{error},</if>
            <if test="times != null">times = #{times},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </set>
        where id = #{id}
    </update>

    <!--删除定时任务日志-->
    <delete id="deleteScheduleJobLogById" parameterType="Long">
        delete from schedule_job_log where id = #{id}
    </delete>
</mapper>